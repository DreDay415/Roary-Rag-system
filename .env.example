# OpenRouter API key — required for the multi-agent crew (Phase 3 + 4)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub personal access token — optional
# Raises the unauthenticated rate limit from 60 to 5,000 req/hr
# Generate at https://github.com/settings/tokens (no scopes required for public repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx
